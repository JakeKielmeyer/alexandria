# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Binaries — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.webp binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.wav binary
*.pdf binary
