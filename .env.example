# Alexandria — environment variable template.
#
# Copy this file to `.env` (gitignored) and fill in real values for local dev.
# For Cloudflare Pages, set the same keys in the dashboard under
# Settings → Environment variables for both "Preview" and "Production".
#
# Every variable consumed by the client MUST be prefixed with VITE_ or Vite
# will not expose it to the browser bundle.

# ---- Required (Supabase) --------------------------------------------------

# URL of your Supabase project. Format: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Anon/public API key (safe to ship in the client — RLS protects the data).
VITE_SUPABASE_ANON_KEY=

# ---- Optional (error tracking, enabled when populated) --------------------

# Sentry DSN for client-side error reporting. Leave empty to no-op.
VITE_SENTRY_DSN=

# ---- Placeholders for future infra (leave empty for beta) -----------------

# Cloudflare Stream account subdomain (e.g. customer-xxxx.cloudflarestream.com)
VITE_CLOUDFLARE_STREAM_ACCOUNT=

# PostHog project key (beta does not ship analytics yet).
VITE_POSTHOG_KEY=
